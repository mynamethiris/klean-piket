# ─────────────────────────────────────────────────────────────────────────────
# Klean - Environment Variables
# Copy file ini ke .env dan isi nilainya.
# Untuk Netlify: tambahkan variabel ini di Site Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# TURSO DATABASE (wajib untuk production)
# Daftar gratis di https://turso.tech → buat database → salin URL dan token
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Untuk development lokal (opsional, otomatis pakai file:local.db jika tidak diset)
# TURSO_DATABASE_URL=file:local.db
